# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# API key used by the language model provider.
# This must be set for the application to run.
OPENAI_API_KEY=your_openai_api_key_here


# -----------------------------------------------------------------------------
# LangSmith Observability Configuration
# -----------------------------------------------------------------------------
# Enables tracing of the application so runs can be inspected in LangSmith.
# Set to "true" to capture traces of prompts, model calls, and outputs.
LANGSMITH_TRACING=true

# API key for LangSmith. Required only if tracing is enabled.
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Optional project name used to group traces in the LangSmith UI.
# Useful when running multiple experiments or applications.
LANGSMITH_PROJECT=case-analysis-demo


# -----------------------------------------------------------------------------
# Optional Runtime Configuration
# -----------------------------------------------------------------------------
# Default model name. Keeping this configurable allows easy switching
# between models without modifying the source code.
MODEL_NAME=gpt-4.1

# Temperature controls randomness of model output.
# Lower values produce more deterministic responses.
MODEL_TEMPERATURE=0
